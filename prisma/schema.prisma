generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model User {
  id        String   @id @default(uuid())
  name      String
  username  String   @unique
  password  String
  role      Role
  status    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  calledOrders   Order[]        @relation("CalledOrders")
  invoiceBatches InvoiceBatch[]
  csvBatches     CsvBatch[]
  attendances           Attendance[]
  attendanceEvents      AttendanceEvent[]
  attendanceViolations  AttendanceViolation[]
}

model Page {
  id                String   @id @default(uuid())
  name              String   @unique
  prefixCode        String   @unique
  lastInvoiceSerial Int      @default(0)
  status            Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  orders Order[]
}

model OrderSource {
  id        String          @id @default(uuid())
  name      String          @unique
  type      OrderSourceType
  status    Boolean         @default(true)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  integrations Integration[]
  orders       Order[]
  adsCostItems AdsCostItem[]
}

model Integration {
  id            String              @id @default(uuid())
  name          String
  slug          String              @unique
  platform      IntegrationPlatform
  sourceId      String
  source        OrderSource         @relation(fields: [sourceId], references: [id], onDelete: Restrict)
  apiKey        String              @unique
  webhookSecret String?
  status        Boolean             @default(true)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  orders Order[]

  @@index([platform])
  @@index([sourceId])
}

model ProductParent {
  id        String   @id @default(uuid())
  sku       String   @unique
  name      String
  status    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products     Product[]
  adsCostItems AdsCostItem[]
}

model Courier {
  id        String   @id @default(uuid())
  name      String   @unique
  slug      String   @unique
  status    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id       String        @id @default(uuid())
  parentId String
  parent   ProductParent @relation(fields: [parentId], references: [id], onDelete: Restrict)

  sku           String   @unique
  name          String
  quantity      Int      @default(1)
  purchasePrice Decimal  @db.Decimal(10, 2)
  sellingPrice  Decimal  @db.Decimal(10, 2)
  status        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  orderItems     OrderItem[]
  purchaseOrders PurchaseOrder[]
}

model Order {
  id        String  @id @default(uuid())
  orderId   String? @unique
  invoiceId String? @unique

  integrationId   String?
  integration     Integration? @relation(fields: [integrationId], references: [id], onDelete: SetNull)
  externalOrderId String?

  sourceId String
  source   OrderSource @relation(fields: [sourceId], references: [id], onDelete: Restrict)

  pageId String?
  page   Page?   @relation(fields: [pageId], references: [id], onDelete: SetNull)

  customerName String
  address      String
  phone        String

  subtotal       Decimal @db.Decimal(10, 2)
  discount       Decimal @default(0) @db.Decimal(10, 2)
  advance        Decimal @default(0) @db.Decimal(10, 2)
  deliveryCharge Decimal @default(0) @db.Decimal(10, 2)
  totalAmount    Decimal @db.Decimal(10, 2)

  orderStatus OrderStatus @default(PENDING_CONFIRMATION)
  courier     String?

  note           String?   @db.Text
  calledByUserId String?
  calledByUser   User?     @relation("CalledOrders", fields: [calledByUserId], references: [id], onDelete: SetNull)
  calledAt       DateTime?

  invoiceDownloaded Boolean @default(false)
  csvDownloaded     Boolean @default(false)

  readyToShipAt DateTime @default(now())

  invoiceBatchItems InvoiceBatchItem[]
  csvBatchItems     CsvBatchItem[]
  items             OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([integrationId, externalOrderId])
  @@index([integrationId])
  @@index([externalOrderId])
  @@index([sourceId])
  @@index([pageId])
  @@index([orderStatus])
  @@index([calledByUserId])
}

model AdsCostUpload {
  id          String   @id @default(uuid())
  uploadDate  DateTime
  fileName    String?
  totalAmount Decimal  @db.Decimal(10, 2)

  items AdsCostItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([uploadDate])
}

model AdsCostItem {
  id String @id @default(uuid())

  uploadId String
  upload   AdsCostUpload @relation(fields: [uploadId], references: [id], onDelete: Cascade)

  campaignName String
  amountSpent  Decimal @db.Decimal(10, 2)

  productParentId String
  productParent   ProductParent @relation(fields: [productParentId], references: [id], onDelete: Restrict)

  sourceId String
  source   OrderSource @relation(fields: [sourceId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([uploadId])
  @@index([productParentId])
  @@index([sourceId])
}

model OrderItem {
  id      String @id @default(uuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  productSku  String
  productName String
  quantity    Int
  unitPrice   Decimal @db.Decimal(10, 2)
  lineTotal   Decimal @db.Decimal(10, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orderId])
  @@index([productId])
  @@index([productSku])
}

model InvoiceBatch {
  id              String   @id @default(uuid())
  batchNo         String   @unique
  courier         String
  totalOrders     Int
  createdByUserId String
  createdByUser   User     @relation(fields: [createdByUserId], references: [id], onDelete: Restrict)
  createdAt       DateTime @default(now())

  items InvoiceBatchItem[]

  @@index([createdByUserId])
  @@index([courier])
}

model InvoiceBatchItem {
  id      String       @id @default(uuid())
  batchId String
  batch   InvoiceBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([batchId, orderId])
  @@index([orderId])
}

model CsvBatch {
  id              String   @id @default(uuid())
  batchNo         String   @unique
  courier         String
  totalOrders     Int
  createdByUserId String
  createdByUser   User     @relation(fields: [createdByUserId], references: [id], onDelete: Restrict)
  createdAt       DateTime @default(now())

  items CsvBatchItem[]

  @@index([createdByUserId])
  @@index([courier])
}

model PurchaseOrder {
  id String @id @default(uuid())

  invoiceNo String @unique

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  productSku  String
  productName String
  parentSku   String

  orderDate DateTime

  quantity     Int
  quantityType String

  productImage String?

  unitPriceUsd      Decimal @db.Decimal(10, 2)
  platformChargeUsd Decimal @db.Decimal(10, 2)
  shippingUsd       Decimal @db.Decimal(10, 2)

  subtotalUsd Decimal @db.Decimal(10, 2)

  status String @default("PENDING")

  note String?

  payments PurchasePayment[]

  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
  receivedOrders PurchaseReceivedOrder[]
}

model PurchasePayment {
  id String @id @default(uuid())

  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  paymentDate DateTime

  paymentType String

  amountUsd Decimal @db.Decimal(10, 2)
  usdRate   Decimal @db.Decimal(10, 2)
  amountBdt Decimal @db.Decimal(10, 2)

  note String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PurchaseReceivedOrder {
  id String @id @default(uuid())

  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  receiveDate DateTime

  receivedQty Int

  packageWeight  Decimal @db.Decimal(10, 2)
  cnfRatePerKg   Decimal @db.Decimal(10, 2)
  totalCnfCharge Decimal @db.Decimal(10, 2)

  otherCostBdt     Decimal @db.Decimal(10, 2)
  paidAmountBdt    Decimal @db.Decimal(10, 2)
  grandTotalBdt    Decimal @db.Decimal(10, 2)
  unitOriginalCost Decimal @db.Decimal(10, 2)

  note String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([purchaseOrderId])
}

model DailyDollarRate {
  id        String   @id @default(uuid())
  rateDate  DateTime
  usdAmount Decimal  @db.Decimal(10, 2)
  bdtAmount Decimal  @db.Decimal(10, 2)
  usdRate   Decimal  @db.Decimal(10, 2)
  note      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([rateDate])
}

model CsvBatchItem {
  id      String   @id @default(uuid())
  batchId String
  batch   CsvBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([batchId, orderId])
  @@index([orderId])
}

enum Role {
  ADMIN
  AGENT
}

enum OrderSourceType {
  SHOPIFY
  LARAVEL
  MANUAL
}

enum IntegrationPlatform {
  SHOPIFY
  LARAVEL
}

enum OrderStatus {
  PENDING_CONFIRMATION
  READY_TO_SHIP
  NO_ANSWER
  PHONE_OFF
  CANCELLED
  DOUBLE_ORDER
  STOCK_OUT
  RETURNED
}


enum AttendanceStatus {
  ON_TIME
  LATE
  ABSENT
}

enum AttendanceEventType {
  ATTEND
  BREAK_START
  BREAK_END
  EVENING_BREAK_START
  EVENING_BREAK_END
  WORK_OFF
}

enum AttendanceViolationType {
  LATE_ATTENDANCE
  BREAK_OVERSTAY
  EVENING_BREAK_OVERSTAY
  MISSING_WORK_OFF
}

model Attendance {
  id             String   @id @default(cuid())

  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  attendanceDate DateTime

  attendAt       DateTime?
  workOffAt      DateTime?

  status         AttendanceStatus @default(ON_TIME)
  lateMinutes    Int              @default(0)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  events         AttendanceEvent[]
  violations     AttendanceViolation[]

  @@unique([userId, attendanceDate])
  @@index([userId])
  @@index([attendanceDate])
}

model AttendanceEvent {
  id              String   @id @default(cuid())

  attendanceId    String
  attendance      Attendance @relation(fields: [attendanceId], references: [id], onDelete: Cascade)

  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  eventType       AttendanceEventType
  eventTime       DateTime @default(now())

  durationMinutes Int?
  isLate          Boolean  @default(false)
  lateMinutes     Int      @default(0)

  createdAt       DateTime @default(now())

  @@index([attendanceId])
  @@index([userId])
  @@index([eventTime])
}

model AttendanceViolation {
  id              String   @id @default(cuid())

  attendanceId    String
  attendance      Attendance @relation(fields: [attendanceId], references: [id], onDelete: Cascade)

  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  violationType   AttendanceViolationType
  violationTime   DateTime @default(now())

  minutes         Int      @default(0)
  message         String

  createdAt       DateTime @default(now())

  @@index([attendanceId])
  @@index([userId])
  @@index([violationTime])
}